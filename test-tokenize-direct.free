// Direct test of tokenize without imports

// Token creation
fn makeToken(kind, value, line, col, length) {
  return { kind: kind, value: value, line: line, col: col, length: length }
}

// Lexer creation
fn createLexer(source) {
  return { source: source, pos: 0, line: 1, col: 1, tokens: [] }
}

// Current character
fn current(lexer) {
  let p = lexer.pos
  let s = lexer.source
  let len = string_length(s)
  if (p >= len) { return "" }
  return charAt(s, p)
}

// Simple tokenize: just split by spaces
fn tokenizeSimple(source) {
  let result = []
  let i = 0
  let word = ""
  
  while (i < string_length(source)) {
    let ch = charAt(source, i)
    
    if (ch == " ") {
      if (word != "") {
        push(result, makeToken("WORD", word, 1, i, string_length(word)))
        word = ""
      }
    } else {
      word = word + ch
    }
    
    i = i + 1
  }
  
  if (word != "") {
    push(result, makeToken("WORD", word, 1, i, string_length(word)))
  }
  
  return result
}

// Test
let tokens = tokenizeSimple("hello world test")
println("Tokens:")
println(str(length(tokens)))

let i = 0
while (i < length(tokens)) {
  let token = tokens[i]
  println(token.kind)
  i = i + 1
}
