// K-StdLib: Assertions Module
// 테스트 검증, 단정(Assertions)

// 검증 결과
struct AssertionResult {
  is_passed: bool,
  assertion_type: string,
  expected: string,
  actual: string,
  error_message: string
}

// 동등성 검증 (==)
function assert_equal(expected: string, actual: string) -> AssertionResult {
  var passed = expected == actual;

  var result = AssertionResult {
    is_passed: passed,
    assertion_type: "assertEqual",
    expected: expected,
    actual: actual,
    error_message: ""
  };

  if !passed {
    result.error_message = "Expected '" + expected + "' but got '" + actual + "'";
  }

  return result;
}

// 정수 동등성 검증
function assert_equal_int(expected: i32, actual: i32) -> AssertionResult {
  var passed = expected == actual;

  var result = AssertionResult {
    is_passed: passed,
    assertion_type: "assertEqual",
    expected: "",
    actual: "",
    error_message: ""
  };

  if !passed {
    result.error_message = "Expected " + expected + " but got " + actual;
  }

  return result;
}

// 부등성 검증 (!=)
function assert_not_equal(not_expected: string, actual: string) -> AssertionResult {
  var passed = not_expected != actual;

  var result = AssertionResult {
    is_passed: passed,
    assertion_type: "assertNotEqual",
    expected: not_expected,
    actual: actual,
    error_message: ""
  };

  if !passed {
    result.error_message = "Expected not equal to '" + not_expected + "' but got '" + actual + "'";
  }

  return result;
}

// 참 검증
function assert_true(condition: bool) -> AssertionResult {
  var result = AssertionResult {
    is_passed: condition,
    assertion_type: "assertTrue",
    expected: "true",
    actual: "",
    error_message: ""
  };

  if !condition {
    result.error_message = "Expected true but got false";
  }

  return result;
}

// 거짓 검증
function assert_false(condition: bool) -> AssertionResult {
  var passed = !condition;

  var result = AssertionResult {
    is_passed: passed,
    assertion_type: "assertFalse",
    expected: "false",
    actual: "",
    error_message: ""
  };

  if !passed {
    result.error_message = "Expected false but got true";
  }

  return result;
}

// Null 검증
function assert_null(value: string) -> AssertionResult {
  var passed = value.len == 0;

  var result = AssertionResult {
    is_passed: passed,
    assertion_type: "assertNull",
    expected: "null",
    actual: value,
    error_message: ""
  };

  if !passed {
    result.error_message = "Expected null but got '" + value + "'";
  }

  return result;
}

// Not Null 검증
function assert_not_null(value: string) -> AssertionResult {
  var passed = value.len > 0;

  var result = AssertionResult {
    is_passed: passed,
    assertion_type: "assertNotNull",
    expected: "not null",
    actual: value,
    error_message: ""
  };

  if !passed {
    result.error_message = "Expected not null but got null";
  }

  return result;
}

// 포함 검증 (Contains)
function assert_contains(haystack: string, needle: string) -> AssertionResult {
  var passed = false;

  // 간단한 포함 검사 (실제로는 문자열 검색 알고리즘 필요)
  if haystack.len >= needle.len && needle.len > 0 {
    passed = true;  // 간소화
  }

  var result = AssertionResult {
    is_passed: passed,
    assertion_type: "assertContains",
    expected: needle,
    actual: haystack,
    error_message: ""
  };

  if !passed {
    result.error_message = "Expected '" + haystack + "' to contain '" + needle + "'";
  }

  return result;
}

// Not Contains 검증
function assert_not_contains(haystack: string, needle: string) -> AssertionResult {
  var passed = true;

  // 간단한 미포함 검사
  if haystack.len >= needle.len && needle.len > 0 {
    passed = false;  // 간소화
  }

  var result = AssertionResult {
    is_passed: passed,
    assertion_type: "assertNotContains",
    expected: needle,
    actual: haystack,
    error_message: ""
  };

  if !passed {
    result.error_message = "Expected '" + haystack + "' not to contain '" + needle + "'";
  }

  return result;
}

// 더 크거나 같음 검증 (>=)
function assert_greater_or_equal(expected: i32, actual: i32) -> AssertionResult {
  var passed = actual >= expected;

  var result = AssertionResult {
    is_passed: passed,
    assertion_type: "assertGreaterOrEqual",
    expected: "",
    actual: "",
    error_message: ""
  };

  if !passed {
    result.error_message = "Expected " + actual + " to be >= " + expected;
  }

  return result;
}

// 더 작거나 같음 검증 (<=)
function assert_less_or_equal(expected: i32, actual: i32) -> AssertionResult {
  var passed = actual <= expected;

  var result = AssertionResult {
    is_passed: passed,
    assertion_type: "assertLessOrEqual",
    expected: "",
    actual: "",
    error_message: ""
  };

  if !passed {
    result.error_message = "Expected " + actual + " to be <= " + expected;
  }

  return result;
}

// 더 큼 검증 (>)
function assert_greater(threshold: i32, actual: i32) -> AssertionResult {
  var passed = actual > threshold;

  var result = AssertionResult {
    is_passed: passed,
    assertion_type: "assertGreater",
    expected: "",
    actual: "",
    error_message: ""
  };

  if !passed {
    result.error_message = "Expected " + actual + " to be > " + threshold;
  }

  return result;
}

// 더 작음 검증 (<)
function assert_less(threshold: i32, actual: i32) -> AssertionResult {
  var passed = actual < threshold;

  var result = AssertionResult {
    is_passed: passed,
    assertion_type: "assertLess",
    expected: "",
    actual: "",
    error_message: ""
  };

  if !passed {
    result.error_message = "Expected " + actual + " to be < " + threshold;
  }

  return result;
}

// 빈 문자열 검증
function assert_empty(value: string) -> AssertionResult {
  var passed = value.len == 0;

  var result = AssertionResult {
    is_passed: passed,
    assertion_type: "assertEmpty",
    expected: "",
    actual: value,
    error_message: ""
  };

  if !passed {
    result.error_message = "Expected empty string but got '" + value + "'";
  }

  return result;
}

// 비어있지 않은 문자열 검증
function assert_not_empty(value: string) -> AssertionResult {
  var passed = value.len > 0;

  var result = AssertionResult {
    is_passed: passed,
    assertion_type: "assertNotEmpty",
    expected: "non-empty",
    actual: value,
    error_message: ""
  };

  if !passed {
    result.error_message = "Expected non-empty string but got empty";
  }

  return result;
}

// 배열 길이 검증
function assert_length(expected_length: i32, actual_length: i32) -> AssertionResult {
  var passed = actual_length == expected_length;

  var result = AssertionResult {
    is_passed: passed,
    assertion_type: "assertLength",
    expected: "",
    actual: "",
    error_message: ""
  };

  if !passed {
    result.error_message = "Expected length " + expected_length + " but got " + actual_length;
  }

  return result;
}

// 검증 결과 출력
function get_assertion_info(result: AssertionResult) -> string {
  var info = result.assertion_type;
  info = info + ": ";

  if result.is_passed {
    info = info + "PASSED";
  } else {
    info = info + "FAILED - ";
    info = info + result.error_message;
  }

  return info;
}

// 모든 검증 통과 확인
function check_all_assertions_passed(results: string) -> bool {
  // 검증 결과 목록에서 실패한 것이 있는지 확인 (간소화)
  return results.len == 0;
}

