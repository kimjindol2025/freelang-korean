// 배열을 JSON 문자열로
function encode_array(arr: i32[]) -> string {
  var result = "[";
  var i = 0;
  for i = 0; i < arr.len; i = i + 1 {
    if i > 0 {
      result = result + ",";
    }
    result = result + arr[i];
  }
  result = result + "]";
  return result;
}

// 숫자를 JSON 문자열로
function encode_number(n: i32) -> string {
  var result = "";
  var num = n;
  if num < 0 {
    result = "-";
    num = -num;
  }
  return result + num;
}

// 문자열을 JSON 문자열로 (이스케이프 처리)
function encode_string(str: string) -> string {
  var result = "\"";
  result = result + str;
  result = result + "\"";
  return result;
}

// 불린을 JSON 문자열로
function encode_bool(b: bool) -> string {
  if b {
    return "true";
  }
  return "false";
}

// null을 JSON 문자열로
function encode_null() -> string {
  return "null";
}
