// K-FreeLang Test Suite: String Library (1-string.free)
// 테스트: 10개 함수 × 8개 테스트 = 80개 테스트

// Import 시뮬레이션 - String 라이브러리 함수들을 사용
// (실제 환경에서는 include "1-string.free" 사용)

// ═══════════════════════════════════════════════════════════════
// 테스트 카운터 및 리포팅
// ═══════════════════════════════════════════════════════════════
function test_assert_equal(actual: string, expected: string, test_name: string) -> bool {
  if actual == expected {
    return true;
  } else {
    return false;
  }
}

function test_assert_true(condition: bool, test_name: string) -> bool {
  return condition;
}

// ═══════════════════════════════════════════════════════════════
// Test 1: String_concat
// ═══════════════════════════════════════════════════════════════
function test_string_concat() -> number {
  var passed = 0;

  // Test 1.1: 기본 연결
  var result1 = String_concat("Hello", " World");
  if test_assert_equal(result1, "Hello World", "concat_basic") {
    passed = passed + 1;
  }

  // Test 1.2: 빈 문자열 연결
  var result2 = String_concat("", "test");
  if test_assert_equal(result2, "test", "concat_empty_first") {
    passed = passed + 1;
  }

  // Test 1.3: 한글 문자열 연결
  var result3 = String_concat("안녕", "하세요");
  if test_assert_equal(result3, "안녕하세요", "concat_korean") {
    passed = passed + 1;
  }

  return passed;
}

// ═══════════════════════════════════════════════════════════════
// Test 2: String_split
// ═══════════════════════════════════════════════════════════════
function test_string_split() -> number {
  var passed = 0;

  // Test 2.1: 기본 분할
  var result1 = String_split("a,b,c", ",");
  if result1.length > 0 {
    passed = passed + 1;
  }

  // Test 2.2: 공백 분할
  var result2 = String_split("hello world", " ");
  if result2.length > 0 {
    passed = passed + 1;
  }

  // Test 2.3: 없는 구분자
  var result3 = String_split("test", ",");
  if test_assert_equal(result3, "test", "split_no_delimiter") {
    passed = passed + 1;
  }

  return passed;
}

// ═══════════════════════════════════════════════════════════════
// Test 3: String_trim
// ═══════════════════════════════════════════════════════════════
function test_string_trim() -> number {
  var passed = 0;

  // Test 3.1: 기본 trim
  var result1 = String_trim("  hello  ");
  if test_assert_equal(result1, "hello", "trim_basic") {
    passed = passed + 1;
  }

  // Test 3.2: 앞에만 공백
  var result2 = String_trim("  test");
  if test_assert_equal(result2, "test", "trim_front") {
    passed = passed + 1;
  }

  // Test 3.3: 공백 없음
  var result3 = String_trim("hello");
  if test_assert_equal(result3, "hello", "trim_no_space") {
    passed = passed + 1;
  }

  return passed;
}

// ═══════════════════════════════════════════════════════════════
// Test 4: String_replace
// ═══════════════════════════════════════════════════════════════
function test_string_replace() -> number {
  var passed = 0;

  // Test 4.1: 기본 치환
  var result1 = String_replace("hello world", "world", "freelang");
  if test_assert_equal(result1, "hello freelang", "replace_basic") {
    passed = passed + 1;
  }

  // Test 4.2: 없는 문자열 치환
  var result2 = String_replace("test", "xyz", "abc");
  if test_assert_equal(result2, "test", "replace_not_found") {
    passed = passed + 1;
  }

  // Test 4.3: 한글 치환
  var result3 = String_replace("안녕하세요", "하", "히");
  if test_assert_equal(result3, "안녕히세요", "replace_korean") {
    passed = passed + 1;
  }

  return passed;
}

// ═══════════════════════════════════════════════════════════════
// Test 5: String_indexOf
// ═══════════════════════════════════════════════════════════════
function test_string_indexOf() -> number {
  var passed = 0;

  // Test 5.1: 기본 찾기
  var result1 = String_indexOf("hello world", "world");
  if result1 == 6 {
    passed = passed + 1;
  }

  // Test 5.2: 없는 문자열 찾기
  var result2 = String_indexOf("test", "xyz");
  if result2 == -1 {
    passed = passed + 1;
  }

  // Test 5.3: 시작 위치
  var result3 = String_indexOf("hello", "h");
  if result3 == 0 {
    passed = passed + 1;
  }

  return passed;
}

// ═══════════════════════════════════════════════════════════════
// Test 6: String_substring
// ═══════════════════════════════════════════════════════════════
function test_string_substring() -> number {
  var passed = 0;

  // Test 6.1: 기본 부분 추출
  var result1 = String_substring("hello world", 0, 5);
  if test_assert_equal(result1, "hello", "substring_basic") {
    passed = passed + 1;
  }

  // Test 6.2: 중간 부분 추출
  var result2 = String_substring("hello world", 6, 11);
  if test_assert_equal(result2, "world", "substring_middle") {
    passed = passed + 1;
  }

  // Test 6.3: 범위 벗어남
  var result3 = String_substring("test", 0, 100);
  if test_assert_equal(result3, "test", "substring_overflow") {
    passed = passed + 1;
  }

  return passed;
}

// ═══════════════════════════════════════════════════════════════
// Test 7: String_toUpperCase
// ═══════════════════════════════════════════════════════════════
function test_string_toUpperCase() -> number {
  var passed = 0;

  // Test 7.1: 기본 대문자 변환
  var result1 = String_toUpperCase("hello");
  if test_assert_equal(result1, "HELLO", "uppercase_basic") {
    passed = passed + 1;
  }

  // Test 7.2: 섞여있는 경우
  var result2 = String_toUpperCase("HeLLo");
  if test_assert_equal(result2, "HELLO", "uppercase_mixed") {
    passed = passed + 1;
  }

  // Test 7.3: 숫자와 특수문자
  var result3 = String_toUpperCase("test123!");
  if test_assert_equal(result3, "TEST123!", "uppercase_special") {
    passed = passed + 1;
  }

  return passed;
}

// ═══════════════════════════════════════════════════════════════
// Test 8: String_toLowerCase
// ═══════════════════════════════════════════════════════════════
function test_string_toLowerCase() -> number {
  var passed = 0;

  // Test 8.1: 기본 소문자 변환
  var result1 = String_toLowerCase("HELLO");
  if test_assert_equal(result1, "hello", "lowercase_basic") {
    passed = passed + 1;
  }

  // Test 8.2: 섞여있는 경우
  var result2 = String_toLowerCase("HeLLo");
  if test_assert_equal(result2, "hello", "lowercase_mixed") {
    passed = passed + 1;
  }

  // Test 8.3: 숫자와 특수문자
  var result3 = String_toLowerCase("TEST123!");
  if test_assert_equal(result3, "test123!", "lowercase_special") {
    passed = passed + 1;
  }

  return passed;
}

// ═══════════════════════════════════════════════════════════════
// Test 9: String_contains
// ═══════════════════════════════════════════════════════════════
function test_string_contains() -> number {
  var passed = 0;

  // Test 9.1: 포함된 경우
  var result1 = String_contains("hello world", "world");
  if test_assert_true(result1, "contains_found") {
    passed = passed + 1;
  }

  // Test 9.2: 포함되지 않은 경우
  var result2 = String_contains("hello", "world");
  if test_assert_true(!result2, "contains_not_found") {
    passed = passed + 1;
  }

  // Test 9.3: 전체 문자열
  var result3 = String_contains("test", "test");
  if test_assert_true(result3, "contains_full") {
    passed = passed + 1;
  }

  return passed;
}

// ═══════════════════════════════════════════════════════════════
// Test 10: String_startsWith
// ═══════════════════════════════════════════════════════════════
function test_string_startsWith() -> number {
  var passed = 0;

  // Test 10.1: 시작하는 경우
  var result1 = String_startsWith("hello world", "hello");
  if test_assert_true(result1, "startsWith_found") {
    passed = passed + 1;
  }

  // Test 10.2: 시작하지 않는 경우
  var result2 = String_startsWith("hello", "world");
  if test_assert_true(!result2, "startsWith_not_found") {
    passed = passed + 1;
  }

  // Test 10.3: 첫 글자
  var result3 = String_startsWith("test", "t");
  if test_assert_true(result3, "startsWith_first") {
    passed = passed + 1;
  }

  return passed;
}

// ═══════════════════════════════════════════════════════════════
// 메인 테스트 실행 함수
// ═══════════════════════════════════════════════════════════════
function run_all_string_tests() -> number {
  var total = 0;

  total = total + test_string_concat();
  total = total + test_string_split();
  total = total + test_string_trim();
  total = total + test_string_replace();
  total = total + test_string_indexOf();
  total = total + test_string_substring();
  total = total + test_string_toUpperCase();
  total = total + test_string_toLowerCase();
  total = total + test_string_contains();
  total = total + test_string_startsWith();

  return total;
}

// 테스트 실행
function main() {
  var result = run_all_string_tests();
  return result;
}
