// Step 9: 에러 처리와 디버깅
// try/catch 기본

출력("=== try/catch 예제 1 ===")

시도 {
  변수 a = 10
  변수 b = 5
  변수 결과 = a / b
  출력("10 / 5 = " + 결과)
} 잡기 (에러) {
  출력("에러 발생: " + 에러)
}

출력("")
출력("=== try/catch 예제 2: 안전한 나눗셈 ===")

함수 안전한_나눗셈(a, b) {
  시도 {
    만약 b == 0 {
      출력("에러: 0으로 나눌 수 없습니다")
      반환 0
    }
    반환 a / b
  } 잡기 (에러) {
    출력("계산 중 에러: " + 에러)
    반환 0
  }
}

변수 결과1 = 안전한_나눗셈(100, 5)
출력("100 / 5 = " + 결과1)

변수 결과2 = 안전한_나눗셈(100, 0)
출력("100 / 0 = " + 결과2)
