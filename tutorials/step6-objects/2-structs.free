// Step 6: 객체와 구조체
// 구조체 활용

구조체 책 {
  제목: 문자열
  저자: 문자열
  페이지: 숫자
  가격: 숫자
}

출력("=== 책 정보 관리 ===")

변수 책1 = 책 {
  제목: "프리랭 완전정복",
  저자: "김철수",
  페이지: 450,
  가격: 35000
}

변수 책2 = 책 {
  제목: "함수형 프로그래밍",
  저자: "이순신",
  페이지: 320,
  가격: 42000
}

출력("책1: " + 책1.제목 + " (저자: " + 책1.저자 + ")")
출력("책2: " + 책2.제목 + " (저자: " + 책2.저자 + ")")

출력("")
출력("=== 구조체 배열 ===")

변수 도서관 = [책1, 책2]

반복 (변수 i = 0; i < 도서관.길이; i += 1) {
  변수 b = 도서관[i]
  출력(b.제목 + ": " + b.가격 + "원")
}
