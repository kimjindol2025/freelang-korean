// Step 6: 객체와 구조체
// 기본 구조체 정의와 사용

구조체 학생 {
  이름: 문자열
  학번: 숫자
  학점: 실수
}

출력("=== 구조체 인스턴스 생성 ===")

변수 학생1 = 학생 {
  이름: "김철수",
  학번: 20210001,
  학점: 3.8
}

출력("이름: " + 학생1.이름)
출력("학번: " + 학생1.학번)
출력("학점: " + 학생1.학점)

출력("")
출력("=== 또 다른 인스턴스 ===")

변수 학생2 = 학생 {
  이름: "이순신",
  학번: 20210002,
  학점: 4.0
}

출력("이름: " + 학생2.이름)
출력("학번: " + 학생2.학번)
출력("학점: " + 학생2.학점)
