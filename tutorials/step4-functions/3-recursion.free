// Step 4: 함수 정의와 호출
// 재귀 함수

출력("=== 팩토리얼 ===")

함수 팩토리얼(n) {
  만약 n <= 1 {
    반환 1
  }
  반환 n * 팩토리얼(n - 1)
}

출력("5! = " + 팩토리얼(5))
출력("10! = " + 팩토리얼(10))

출력("")
출력("=== 피보나치 수열 ===")

함수 피보나치(n) {
  만약 n <= 1 {
    반환 n
  }
  반환 피보나치(n - 1) + 피보나치(n - 2)
}

출력("피보나치(0) = " + 피보나치(0))
출력("피보나치(5) = " + 피보나치(5))
출력("피보나치(10) = " + 피보나치(10))

출력("")
출력("=== 역순 출력 ===")

함수 역순_출력(n) {
  만약 n < 1 {
    반환
  }
  출력(n)
  역순_출력(n - 1)
}

역순_출력(5)
