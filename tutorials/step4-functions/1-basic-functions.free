// Step 4: 함수 정의와 호출
// 기본 함수

출력("=== 기본 함수 ===")

// 인자 없음, 반환값 없음
함수 인사() {
  출력("안녕하세요!")
}

인사()

출력("")
출력("=== 반환값이 있는 함수 ===")

// 반환값이 있는 함수
함수 더하기(a, b) {
  반환 a + b
}

변수 합 = 더하기(5, 3)
출력("5 + 3 = " + 합)

변수 곱 = 더하기(10, 20)
출력("10 + 20 = " + 곱)

출력("")
출력("=== 인자가 있는 함수 ===")

함수 인사하기(이름) {
  출력("안녕하세요, " + 이름 + "!")
}

인사하기("김철수")
인사하기("이순신")

출력("")
출력("=== 여러 인자 ===")

함수 소개(이름, 나이, 직업) {
  출력("이름: " + 이름)
  출력("나이: " + 나이)
  출력("직업: " + 직업)
}

소개("박영희", 28, "개발자")
