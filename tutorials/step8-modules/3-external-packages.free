// Step 8: 모듈과 라이브러리
// JSON 라이브러리 활용

출력("=== JSON 직렬화 ===")

구조체 사용자 {
  이름: 문자열
  나이: 숫자
  이메일: 문자열
}

변수 user = 사용자 {
  이름: "김철수",
  나이: 25,
  이메일: "kim@example.com"
}

// JSON으로 변환 (K-StdLib JSON 함수)
변수 json_str = JSON_stringify(user)
출력("JSON: " + json_str)

출력("")
출력("=== JSON 파싱 ===")

변수 json_data = "{\"이름\": \"이순신\", \"나이\": 40}"

// JSON 파싱 (K-StdLib JSON 함수)
변수 parsed = JSON_parse(json_data)

출력("파싱된 데이터")
출력(parsed)
