// Step 8: 모듈과 라이브러리
// 모듈 import/export

// K-StdLib 함수 사용 예제

출력("=== K-StdLib String 함수 ===")

// 문자열 결합
변수 결과1 = 문자열_concat("안녕", "하세요")
출력("결과: " + 결과1)

// 문자열 길이
변수 길이 = 문자열_length("프리랭")
출력("길이: " + 길이)

// 문자열 포함
변수 포함 = 문자열_contains("프리랭", "랭")
출력("포함 여부: " + 포함)

출력("")
출력("=== K-StdLib Array 함수 ===")

// 배열 길이
변수 배열 = [1, 2, 3, 4, 5]
변수 배열_길이 = 배열_length(배열)
출력("배열 길이: " + 배열_길이)

// 배열 포함
변수 배열_포함 = 배열_contains(배열, 3)
출력("3 포함 여부: " + 배열_포함)
