// Step 8: 모듈과 라이브러리
// 표준 라이브러리 활용

출력("=== K-StdLib Math 함수 ===")

변수 합 = 수학_add(10, 20)
변수 차 = 수학_subtract(30, 10)
변수 곱 = 수학_multiply(5, 6)
변수 나눗셈 = 수학_divide(100, 4)

출력("10 + 20 = " + 합)
출력("30 - 10 = " + 차)
출력("5 * 6 = " + 곱)
출력("100 / 4 = " + 나눗셈)

출력("")
출력("=== 더 많은 Math 함수 ===")

변수 절댓값 = 수학_abs(-10)
변수 최대값 = 수학_max(15, 25, 5)
변수 올림 = 수학_ceil(3.2)
변수 내림 = 수학_floor(3.8)

출력("절댓값(-10) = " + 절댓값)
출력("최대값(15, 25, 5) = " + 최대값)
출력("올림(3.2) = " + 올림)
출력("내림(3.8) = " + 내림)
