// ┌─────────────────────────────────────────────────────────────┐
// │ K-FreeLang E2E 파이프라인 통합 테스트                        │
// │ 파서 → IR 생성 → 최적화 → 코드 생성 전체 검증 (2026-03-27)  │
// └─────────────────────────────────────────────────────────────┘

// ============================================================
// 📋 1. 기본 파이프라인 E2E 테스트
// ============================================================

테스트 E2E_변수선언_전체파이프라인 {
  변수 소스코드 = "
    변수 x = 42
    변수 y = x + 8
    출력(y)
  "

  // 1. 렉싱 (Lexing)
  변수 토큰들 = 렉서실행(소스코드)
  검증(길이(토큰들) > 0, "렉싱 실패")

  // 2. 파싱 (Parsing)
  변수 AST = 파서실행(토큰들)
  검증(AST != 공값, "파싱 실패")

  // 3. 의미론 분석 (Semantic Analysis)
  변수 분석결과 = 의미론분석(AST)
  검증(분석결과.오류들 == [], "의미론 분석 오류")

  // 4. IR 생성 (IR Generation)
  변수 IR = IR생성기실행(분석결과)
  검증(IR.블록들 != 공값, "IR 생성 실패")

  // 5. IR 최적화 (IR Optimization)
  변수 최적화된IR = IR최적화실행(IR)
  검증(길이(최적화된IR.블록들) <= 길이(IR.블록들), "최적화가 명령어를 증가시킴")

  // 6. 코드 생성 (Code Generation)
  변수 생성코드 = 코드생성기실행(최적화된IR)
  검증(생성코드 != "", "코드 생성 실패")

  출력("✓ E2E 파이프라인 성공: 변수선언")
}

테스트 E2E_함수정의_전체파이프라인 {
  변수 소스코드 = "
    함수 add(a: 숫자, b: 숫자) → 숫자 {
      반환 a + b
    }

    변수 결과 = add(3, 4)
    출력(결과)
  "

  변수 토큰들 = 렉서실행(소스코드)
  변수 AST = 파서실행(토큰들)
  변수 분석결과 = 의미론분석(AST)
  검증(분석결과.함수들 != 공값, "함수 분석 실패")

  변수 IR = IR생성기실행(분석결과)
  변수 최적화된IR = IR최적화실행(IR)
  변수 생성코드 = 코드생성기실행(최적화된IR)

  검증(포함(생성코드, "function") 아니면 포함(생성코드, "def"), "함수 정의 코드 생성 실패")
  출력("✓ E2E 파이프라인 성공: 함수정의")
}

// ============================================================
// 🔄 2. 제어 흐름 E2E 테스트
// ============================================================

테스트 E2E_if문_제어흐름 {
  변수 소스코드 = "
    변수 x = 10
    만약 x > 5 {
      출력(\"크다\")
    } 아니면 {
      출력(\"작다\")
    }
  "

  변수 토큰들 = 렉서실행(소스코드)
  변수 AST = 파서실행(토큰들)
  변수 분석결과 = 의미론분석(AST)
  변수 IR = IR생성기실행(분석결과)

  // IR에 조건 분기가 있는지 확인
  변수 분기블록수 = 0
  반복 변수 i = 0; i < 길이(IR.블록들); i = i + 1 {
    변수 블록 = IR.블록들[i]
    만약 블록.타입 == "조건분기" {
      분기블록수 = 분기블록수 + 1
    }
  }

  검증(분기블록수 > 0, "조건 분기 IR 생성 실패")
  출력("✓ E2E 파이프라인 성공: if문 제어흐름")
}

테스트 E2E_for루프_최적화 {
  변수 소스코드 = "
    변수 합계 = 0
    반복 변수 i = 0; i < 100; i = i + 1 {
      합계 = 합계 + i
    }
    출력(합계)
  "

  변수 토큰들 = 렉서실행(소스코드)
  변수 AST = 파서실행(토큰들)
  변수 분석결과 = 의미론분석(AST)
  변수 IR = IR생성기실행(분석결과)

  // 최적화 전 명령어 수
  변수 최적화전명령어수 = 0
  반복 변수 i = 0; i < 길이(IR.블록들); i = i + 1 {
    최적화전명령어수 = 최적화전명령어수 + 길이(IR.블록들[i].명령어들)
  }

  변수 최적화된IR = IR최적화실행(IR)

  // 최적화 후 명령어 수
  변수 최적화후명령어수 = 0
  반복 변수 i = 0; i < 길이(최적화된IR.블록들); i = i + 1 {
    최적화후명령어수 = 최적화후명령어수 + 길이(최적화된IR.블록들[i].명령어들)
  }

  검증(최적화후명령어수 <= 최적화전명령어수, "최적화 실패: 명령어 증가")
  출력("✓ E2E 파이프라인 성공: for루프 최적화 (\"
    + 최적화전명령어수 + \" → \"
    + 최적화후명령어수 + \")")
}

// ============================================================
// 🎯 3. 패턴 매칭 E2E 테스트 (P2)
// ============================================================

테스트 E2E_패턴매칭_E2E {
  변수 소스코드 = "
    변수 값 = 42
    변수 결과 = 매칭 값 {
      경우 0..10 → \"작음\"
      경우 11..50 → \"중간\"
      경우 _ → \"큼\"
    }
    출력(결과)
  "

  변수 토큰들 = 렉서실행(소스코드)
  변수 AST = 파서실행(토큰들)
  변수 분석결과 = 의미론분석(AST)
  변수 IR = IR생성기실행(분석결과)

  // 패턴 매칭 IR 검증
  변수 패턴블록수 = 0
  반복 변수 i = 0; i < 길이(IR.블록들); i = i + 1 {
    만약 포함(IR.블록들[i].설명, "패턴") {
      패턴블록수 = 패턴블록수 + 1
    }
  }

  검증(패턴블록수 > 0, "패턴 매칭 IR 생성 실패")
  출력("✓ E2E 파이프라인 성공: 패턴 매칭")
}

// ============================================================
// ⚡ 4. 비동기/동시성 E2E 테스트 (P2)
// ============================================================

테스트 E2E_async_await_E2E {
  변수 소스코드 = "
    비동기 함수 fetch_data() → 문자열 {
      대기 지연(100)
      반환 \"데이터\"
    }

    비동기 함수 main() → 공집합 {
      변수 데이터 = 대기 fetch_data()
      출력(데이터)
    }
  "

  변수 토큰들 = 렉서실행(소스코드)
  변수 AST = 파서실행(토큰들)
  변수 분석결과 = 의미론분석(AST)

  검증(분석결과.비동기함수수 >= 2, "비동기 함수 분석 실패")

  변수 IR = IR생성기실행(분석결과)
  검증(IR.블록들 != 공값, "비동기 IR 생성 실패")

  출력("✓ E2E 파이프라인 성공: async/await")
}

테스트 E2E_동시실행_E2E {
  변수 소스코드 = "
    뮤텍스 카운터 {
      숫자 = 0
    }

    함수 작업() → 공집합 {
      동시실행 {
        카운터.잠금()
        카운터.값 = 카운터.값 + 1
        카운터.해제()
      }
    }
  "

  변수 토큰들 = 렉서실행(소스코드)
  변수 AST = 파서실행(토큰들)
  변수 분석결과 = 의미론분석(AST)

  검증(분석결과.뮤텍스수 > 0, "뮤텍스 분석 실패")

  변수 IR = IR생성기실행(분석결과)
  출력("✓ E2E 파이프라인 성공: 동시실행")
}

// ============================================================
// 🔍 5. 상수 폴딩 최적화 검증
// ============================================================

테스트 E2E_상수폴딩_최적화검증 {
  변수 소스코드 = "
    변수 x = 10 + 20 + 30
    변수 y = 5 * 4 * 2
    변수 z = (x > 50) ? 100 : 200
    출력(x + y + z)
  "

  변수 토큰들 = 렉서실행(소스코드)
  변수 AST = 파서실행(토큰들)
  변수 분석결과 = 의미론분석(AST)
  변수 IR = IR생성기실행(분석결과)

  // 최적화 전 LoadConst 개수
  변수 최적화전로드콘스트 = 0
  반복 변수 i = 0; i < 길이(IR.블록들); i = i + 1 {
    반복 변수 j = 0; j < 길이(IR.블록들[i].명령어들); j = j + 1 {
      변수 명령어 = IR.블록들[i].명령어들[j]
      만약 명령어.타입 == "LoadConst" {
        최적화전로드콘스트 = 최적화전로드콘스트 + 1
      }
    }
  }

  변수 최적화된IR = IR최적화실행(IR)

  // 최적화 후 LoadConst 개수
  변수 최적화후로드콘스트 = 0
  반복 변수 i = 0; i < 길이(최적화된IR.블록들); i = i + 1 {
    반복 변수 j = 0; j < 길이(최적화된IR.블록들[i].명령어들); j = j + 1 {
      변수 명령어 = 최적화된IR.블록들[i].명령어들[j]
      만약 명령어.타입 == "LoadConst" {
        최적화후로드콘스트 = 최적화후로드콘스트 + 1
      }
    }
  }

  검증(최적화후로드콘스트 < 최적화전로드콘스트, "상수 폴딩 최적화 실패")
  출력("✓ E2E 상수 폴딩 최적화: \"
    + 최적화전로드콘스트 + \" → \"
    + 최적화후로드콘스트)
}

테스트 E2E_데드코드제거_최적화검증 {
  변수 소스코드 = "
    함수 test() → 공집합 {
      출력(\"실행됨\")
      반환
      출력(\"도달불가\")
      출력(\"도달불가\")
    }
  "

  변수 토큰들 = 렉서실행(소스코드)
  변수 AST = 파서실행(토큰들)
  변수 분석결과 = 의미론분석(AST)
  변수 IR = IR생성기실행(분석결과)

  변수 최적화전명령어 = 0
  반복 변수 i = 0; i < 길이(IR.블록들); i = i + 1 {
    최적화전명령어 = 최적화전명령어 + 길이(IR.블록들[i].명령어들)
  }

  변수 최적화된IR = IR최적화실행(IR)

  변수 최적화후명령어 = 0
  반복 변수 i = 0; i < 길이(최적화된IR.블록들); i = i + 1 {
    최적화후명령어 = 최적화후명령어 + 길이(최적화된IR.블록들[i].명령어들)
  }

  검증(최적화후명령어 < 최적화전명령어, "데드 코드 제거 실패")
  출력("✓ E2E 데드 코드 제거: \"
    + 최적화전명령어 + \" → \"
    + 최적화후명령어)
}

// ============================================================
// 🎯 6. PIPA 검증 E2E 테스트
// ============================================================

테스트 E2E_개인정보검증_파이프라인 {
  변수 소스코드 = "
    함수 validate_user(rrn: 문자열, phone: 문자열) → 참거짓 {
      변수 rrn유효 = RRN_유효성검증(rrn)
      변수 phone유효 = 휴대폰번호_유효성검증(phone)
      반환 rrn유효 아니면 phone유효
    }
  "

  변수 토큰들 = 렉서실행(소스코드)
  변수 AST = 파서실행(토큰들)
  변수 분석결과 = 의미론분석(AST)
  변수 IR = IR생성기실행(분석결과)

  // 표준 라이브러리 호출이 있는지 확인
  변수 stdlib호출수 = 0
  반복 변수 i = 0; i < 길이(IR.블록들); i = i + 1 {
    반복 변수 j = 0; j < 길이(IR.블록들[i].명령어들); j = j + 1 {
      변수 명령어 = IR.블록들[i].명령어들[j]
      만약 명령어.타입 == "FunctionCall" {
        만약 포함(명령어.함수이름, "RRN") 아니면 포함(명령어.함수이름, "phone") {
          stdlib호출수 = stdlib호출수 + 1
        }
      }
    }
  }

  검증(stdlib호출수 > 0, "표준 라이브러리 호출 실패")
  출력("✓ E2E 파이프라인 성공: PIPA 검증 (\" + stdlib호출수 + \"개 stdlib 호출)")
}

// ============================================================
// 📊 7. 통합 성능 벤치마크
// ============================================================

테스트 E2E_성능벤치마크_전체파이프라인 {
  변수 소스코드 = "
    함수 fibonacci(n: 숫자) → 숫자 {
      만약 n <= 1 {
        반환 n
      }
      반환 fibonacci(n - 1) + fibonacci(n - 2)
    }

    함수 main() → 공집합 {
      변수 결과 = fibonacci(10)
      출력(결과)
    }
  "

  변수 시작시간 = 현재시간()

  // 1. 렉싱
  변수 토큰들 = 렉서실행(소스코드)
  변수 렉싱시간 = 현재시간() - 시작시간

  // 2. 파싱
  변수 파싱시작 = 현재시간()
  변수 AST = 파서실행(토큰들)
  변수 파싱시간 = 현재시간() - 파싱시작

  // 3. 의미론 분석
  변수 의미론시작 = 현재시간()
  변수 분석결과 = 의미론분석(AST)
  변수 의미론시간 = 현재시간() - 의미론시작

  // 4. IR 생성
  변수 IR생성시작 = 현재시간()
  변수 IR = IR생성기실행(분석결과)
  변수 IR생성시간 = 현재시간() - IR생성시작

  // 5. IR 최적화
  변수 최적화시작 = 현재시간()
  변수 최적화된IR = IR최적화실행(IR)
  변수 최적화시간 = 현재시간() - 최적화시작

  // 6. 코드 생성
  변수 코드생성시작 = 현재시간()
  변수 생성코드 = 코드생성기실행(최적화된IR)
  변수 코드생성시간 = 현재시간() - 코드생성시작

  변수 총시간 = 현재시간() - 시작시간

  // 검증: 각 단계가 1초 이내 완료
  검증(렉싱시간 < 1000, "렉싱 성능 미달: " + 렉싱시간 + "ms")
  검증(파싱시간 < 1000, "파싱 성능 미달: " + 파싱시간 + "ms")
  검증(의미론시간 < 2000, "의미론 분석 성능 미달: " + 의미론시간 + "ms")
  검증(IR생성시간 < 1000, "IR 생성 성능 미달: " + IR생성시간 + "ms")
  검증(최적화시간 < 500, "IR 최적화 성능 미달: " + 최적화시간 + "ms")
  검증(코드생성시간 < 1000, "코드 생성 성능 미달: " + 코드생성시간 + "ms")
  검증(총시간 < 7000, "전체 파이프라인 성능 미달: " + 총시간 + "ms")

  출력("✓ E2E 성능 벤치마크 통과:")
  출력("  렉싱: " + 렉싱시간 + "ms")
  출력("  파싱: " + 파싱시간 + "ms")
  출력("  의미론: " + 의미론시간 + "ms")
  출력("  IR생성: " + IR생성시간 + "ms")
  출력("  최적화: " + 최적화시간 + "ms")
  출력("  코드생성: " + 코드생성시간 + "ms")
  출력("  총시간: " + 총시간 + "ms")
}

