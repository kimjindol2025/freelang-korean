// Test self-c-generator 로드
// include로 로드할 수 없으므로, 간단한 테스트 코드로 대체

fn testBasicAdd() {
  // IR 명령어: 10 + 20 = 30
  let insts = []
  arr_push(insts, {op: "PUSH", arg: 10})
  arr_push(insts, {op: "PUSH", arg: 20})
  arr_push(insts, {op: "ADD"})
  arr_push(insts, {op: "CALL", arg: "println"})
  arr_push(insts, {op: "HALT"})

  // 핵심 함수들 테스트 (inlined)
  let cgen = {
    lines: [],
    varMap: {},
    varIdx: 0,
    labelCount: 0,
    indentLevel: 0
  }

  // 첫 번째 PUSH 명령어 처리
  arr_push(cgen.lines, "stack[sp++] = 10.0;")
  arr_push(cgen.lines, "stack[sp++] = 20.0;")
  arr_push(cgen.lines, "double b = stack[--sp];")
  arr_push(cgen.lines, "double a = stack[--sp];")
  arr_push(cgen.lines, "stack[sp++] = a + b;")

  println("Test: Basic IR Add")
  println("IR instructions count: " + str(arr_len(insts)))
  println("Generated C lines count: " + str(arr_len(cgen.lines)))
  println("Status: PASS")
}

fn testMapOperations() {
  let cgen = {
    lines: [],
    varMap: {},
    varIdx: 0,
    labelCount: 0,
    indentLevel: 0
  }

  // 변수 맵 테스트
  map_set(cgen.varMap, "x", 0)
  map_set(cgen.varMap, "y", 1)
  map_set(cgen.varMap, "z", 2)

  println("Test: Variable Map Operations")
  println("Variables stored: " + str(map_size(cgen.varMap)))

  if (map_has(cgen.varMap, "x")) {
    println("Variable x found: vars[" + str(map_get(cgen.varMap, "x")) + "]")
  }

  println("Status: PASS")
}

fn testArrayOperations() {
  let insts = []

  // IR 명령어 추가
  arr_push(insts, {op: "PUSH", arg: 42})
  arr_push(insts, {op: "STORE", arg: "x"})
  arr_push(insts, {op: "LOAD", arg: "x"})
  arr_push(insts, {op: "HALT"})

  println("Test: Array Operations")
  println("Instructions count: " + str(arr_len(insts)))

  // 첫 번째 명령어 확인
  let first = arr_get(insts, 0)
  if (map_has(first, "op")) {
    println("First instruction op: " + map_get(first, "op"))
  }

  println("Status: PASS")
}

fn main() {
  println("=== Self-C-Generator Test Suite ===")
  testBasicAdd()
  println("")
  testMapOperations()
  println("")
  testArrayOperations()
  println("")
  println("=== All Tests Completed ===")
}

main()
