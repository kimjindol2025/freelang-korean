fn test() -> i32 {
  var pos: i32 = 5
  var len: i32 = 10
  var source: string = "hello"
  
  if pos < len {
    pos = pos + 1
    while pos < len {
      var ch: string = "x"
      if ch == "\"" {
        pos = pos + 1
        while pos < len {
          if ch == "\\" {
            pos = pos + 2
          } else {
            if ch == "\n" {
              pos = pos + 1
            }
            pos = pos + 1
          }
        }
      }
    }
  }
  return 0
}

var x: i32 = test()
