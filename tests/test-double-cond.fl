fn char_at(s: string, i: i32) -> string {
  return ""
}

fn test() -> i32 {
  var source: string = "hello"
  var pos: i32 = 0
  var len: i32 = 5
  
  while pos < len && char_at(source, pos) != "\"" {
    if char_at(source, pos) == "\\" && pos + 1 < len {
      pos = pos + 2
    } else {
      pos = pos + 1
    }
  }
  return 0
}

var x: i32 = test()
