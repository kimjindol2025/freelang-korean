  if (ch == "Y") { return 1 }
  if (ch == "Z") { return 1 }
  if (ch == "_") { return 1 }
  return 0
}

// isDigit function
fn isDigit(ch) {
  if (ch == "") { return 0 }
  if (ch == "0") { return 1 }
  if (ch == "1") { return 1 }
  if (ch == "2") { return 1 }
  if (ch == "3") { return 1 }
  if (ch == "4") { return 1 }
  if (ch == "5") { return 1 }
  if (ch == "6") { return 1 }
  if (ch == "7") { return 1 }
  if (ch == "8") { return 1 }
  if (ch == "9") { return 1 }
  return 0
}

// isWhitespace function
fn isWhitespace(ch) {
  if (ch == " ") { return 1 }
  if (ch == "\t") { return 1 }
  if (ch == "\n") { return 1 }
  return 0
}

// skipWhitespace function
fn skipWhitespace(lexer) {
  let ch = current(lexer)
  while (ch != "" && isWhitespace(ch) == 1) {
    advance(lexer)
    ch = current(lexer)
  }
}

