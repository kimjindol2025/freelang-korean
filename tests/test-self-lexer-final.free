  if (ch == "i") { return 1 }
  if (ch == "j") { return 1 }
  if (ch == "k") { return 1 }
  if (ch == "l") { return 1 }
  if (ch == "m") { return 1 }
  if (ch == "n") { return 1 }
  if (ch == "o") { return 1 }
  if (ch == "p") { return 1 }
  if (ch == "q") { return 1 }
  if (ch == "r") { return 1 }
  if (ch == "s") { return 1 }
  if (ch == "t") { return 1 }
  if (ch == "u") { return 1 }
  if (ch == "v") { return 1 }
  if (ch == "w") { return 1 }
  if (ch == "x") { return 1 }
  if (ch == "y") { return 1 }
  if (ch == "z") { return 1 }
  if (ch == "A") { return 1 }
  if (ch == "B") { return 1 }
  if (ch == "C") { return 1 }
  if (ch == "D") { return 1 }
  if (ch == "E") { return 1 }
  if (ch == "F") { return 1 }
