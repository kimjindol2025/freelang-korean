// Import self-lexer functions
// (In a real environment, these would be imported from self-lexer.fl)

// Token creation
fn makeToken(kind, value, line, col, length) {
  return { kind: kind, value: value, line: line, col: col, length: length }
}

// Lexer creation
fn createLexer(source) {
  return { source: source, pos: 0, line: 1, col: 1, tokens: [] }
}

// Current character
fn current(lexer) {
  let p = lexer.pos
  let s = lexer.source
  let len = string_length(s)
  if (p >= len) { return "" }
  return charAt(s, p)
}

// Advance position
fn advance(lexer) {
  let ch = current(lexer)
  if (ch == "\n") {
    lexer.line = lexer.line + 1
    lexer.col = 1
  } else {
    lexer.col = lexer.col + 1
  }
  lexer.pos = lexer.pos + 1
}

// isAlpha function
fn isAlpha(ch) {
  if (ch == "") { return 0 }
  // Simple implementation with direct character comparison
  if (ch == "a") { return 1 }
  if (ch == "b") { return 1 }
  if (ch == "c") { return 1 }
  if (ch == "d") { return 1 }
  if (ch == "e") { return 1 }
  if (ch == "f") { return 1 }
  if (ch == "g") { return 1 }
