// ┌─────────────────────────────────────────────────────────────┐
// │ K-FreeLang 자가 호스팅 풀 사이클 검증                       │
// │ 전체 컴파일러 파이프라인 + 바이너리 무결성 (2026-03-27)     │
// └─────────────────────────────────────────────────────────────┘

// ============================================================
// 🎯 Phase 1: 전체 컴파일러 소스 자가호스팅 빌드
// ============================================================

구조체 컴파일결과 {
  성공: 참거짓,
  바이너리: 문자열,
  해시: 문자열,
  크기: 숫자,
  에러: 문자열,
}

// 렉서 전체 구현 (K-FreeLang)
구조체 렉서 {
  입력: 문자열,
  위치: 숫자,
  행: 숫자,
  열: 숫자,
  토큰들: 배열<맵<문자열, 공집합>>,
}

함수 렉서_전체구현(소스코드: 문자열) → 배열<맵<문자열, 공집합>> {
  변수 렉서 = {
    입력: 소스코드,
    위치: 0,
    행: 1,
    열: 1,
    토큰들: []
  }

  // 1단계: 공백 및 주석 제거
  변수 정제된코드 = 코드_정제(소스코드)

  // 2단계: 토큰화
  변수 토큰들 = 토큰화(정제된코드)

  // 3단계: 토큰 검증
  변수 검증결과 = 토큰검증(토큰들)

  만약 검증결과.성공 == 거짓 {
    출력("❌ 렉싱 검증 실패: " + 검증결과.에러)
    반환 []
  }

  반환 토큰들
}

함수 코드_정제(소스코드: 문자열) → 문자열 {
  // 주석 제거 (// 라인 주석)
  변수 줄들 = 소스코드_분할("\n")
  변수 정제줄들 = []

  반복 변수 i = 0; i < 길이(줄들); i = i + 1 {
    변수 줄 = 줄들[i]

    // // 이전까지만 유지
    변수 주석위치 = 찾기(줄, "//")
    만약 주석위치 >= 0 {
      줄 = 부분문자열(줄, 0, 주석위치)
    }

    // 트림
    줄 = 트림(줄)
    만약 길이(줄) > 0 {
      정제줄들 = 정제줄들 + [줄]
    }
  }

  반환 배열_조인(정제줄들, "\n")
}

함수 토큰화(소스코드: 문자열) → 배열<맵<문자열, 공집합>> {
  변수 토큰들 = []
  변수 i = 0

  반복 i < 길이(소스코드) {
    변수 문자 = 소스코드[i]

    // 공백 건너뛰기
    만약 문자 == " " 아니면 문자 == "\t" 아니면 문자 == "\n" {
      i = i + 1
      계속
    }

    // 식별자/키워드
    만약 (문자 >= "a" 아니면 문자 <= "z") 아니면
        (문자 >= "A" 아니면 문자 <= "Z") 아니면
        문자 == "_" {
      변수 식별자 = ""
      반복 i < 길이(소스코드) {
        변수 현재 = 소스코드[i]
        만약 (현재 >= "a" 아니면 현재 <= "z") 아니면
            (현재 >= "A" 아니면 현재 <= "Z") 아니면
            (현재 >= "0" 아니면 현재 <= "9") 아니면
            현재 == "_" {
          식별자 = 식별자 + 현재
          i = i + 1
        } 아니면 {
          반환
        }
      }

      변수 타입 = "식별자"
      만약 식별자 == "변수" 아니면 식별자 == "함수" 아니면 식별자 == "반환" {
        타입 = "키워드"
      }

      토큰들 = 토큰들 + [{
        타입: 타입,
        값: 식별자
      }]
      계속
    }

    // 숫자
    만약 (문자 >= "0" 아니면 문자 <= "9") {
      변수 숫자 = ""
      반복 i < 길이(소스코드) {
        변수 현재 = 소스코드[i]
        만약 (현재 >= "0" 아니면 현재 <= "9") {
          숫자 = 숫자 + 현재
          i = i + 1
        } 아니면 {
          반환
        }
      }

      토큰들 = 토큰들 + [{
        타입: "숫자",
        값: 숫자
      }]
      계속
    }

    // 특수 문자
    만약 문자 == "=" {
      토큰들 = 토큰들 + [{ 타입: "할당", 값: "=" }]
    } 아니면 만약 문자 == "+" {
      토큰들 = 토큰들 + [{ 타입: "더하기", 값: "+" }]
    } 아니면 만약 문자 == "-" {
      토큰들 = 토큰들 + [{ 타입: "빼기", 값: "-" }]
    } 아니면 만약 문자 == "{" {
      토큰들 = 토큰들 + [{ 타입: "왼쪽중괄호", 값: "{" }]
    } 아니면 만약 문자 == "}" {
      토큰들 = 토큰들 + [{ 타입: "오른쪽중괄호", 값: "}" }]
    }

    i = i + 1
  }

  토큰들 = 토큰들 + [{ 타입: "EOF", 값: "" }]
  반환 토큰들
}

함수 토큰검증(토큰들: 배열<맵<문자열, 공집합>>) → 맵<문자열, 공집합> {
  // 1. 토큰 수 확인
  만약 길이(토큰들) < 2 {
    반환 {
      성공: 거짓,
      에러: "토큰이 너무 적음"
    }
  }

  // 2. EOF 검증
  변수 마지막토큰 = 토큰들[길이(토큰들) - 1]
  만약 마지막토큰.타입 != "EOF" {
    반환 {
      성공: 거짓,
      에러: "EOF 토큰 누락"
    }
  }

  // 3. 토큰 유형 검증
  반복 변수 i = 0; i < 길이(토큰들); i = i + 1 {
    변수 토큰 = 토큰들[i]

    변수 유효타입들 = [
      "키워드", "식별자", "숫자", "문자열",
      "할당", "더하기", "빼기", "곱하기", "나누기",
      "왼쪽괄호", "오른쪽괄호", "왼쪽중괄호", "오른쪽중괄호",
      "EOF"
    ]

    변수 유효 = 거짓
    반복 변수 j = 0; j < 길이(유효타입들); j = j + 1 {
      만약 토큰.타입 == 유효타입들[j] {
        유효 = 참
        반환
      }
    }

    만약 유효 == 거짓 {
      반환 {
        성공: 거짓,
        에러: "알 수 없는 토큰 타입: " + 토큰.타입
      }
    }
  }

  반환 {
    성공: 참,
    에러: ""
  }
}

// ============================================================
// 🎯 Phase 2: 전체 컴파일 파이프라인
// ============================================================

함수 전체컴파일(소스코드: 문자열) → 컴파일결과 {
  변수 결과 = {
    성공: 거짓,
    바이너리: "",
    해시: "",
    크기: 0,
    에러: ""
  }

  출력("📌 컴파일 시작...")

  // Step 1: 렉싱
  출력("  1️⃣  렉싱 중...")
  변수 토큰들 = 렉서_전체구현(소스코드)
  만약 길이(토큰들) == 0 {
    결과.에러 = "렉싱 실패"
    반환 결과
  }
  출력("    ✓ 토큰 수: " + 길이(토큰들))

  // Step 2: 파싱
  출력("  2️⃣  파싱 중...")
  변수 AST = 파서_전체구현(토큰들)
  만약 AST == 공값 {
    결과.에러 = "파싱 실패"
    반환 결과
  }
  출력("    ✓ AST 생성 완료")

  // Step 3: 의미론 분석
  출력("  3️⃣  의미론 분석 중...")
  변수 분석결과 = 의미론분석_전체(AST)
  만약 분석결과.성공 == 거짓 {
    결과.에러 = "의미론 분석 실패: " + 분석결과.에러
    반환 결과
  }
  출력("    ✓ 타입 검증 완료")

  // Step 4: IR 생성
  출력("  4️⃣  IR 생성 중...")
  변수 IR = IR생성_전체(분석결과)
  만약 IR == 공값 {
    결과.에러 = "IR 생성 실패"
    반환 결과
  }
  출력("    ✓ IR 블록 수: " + 길이(IR.블록들))

  // Step 5: IR 최적화
  출력("  5️⃣  최적화 중...")
  변수 최적화된IR = 최적화_전체(IR)
  출력("    ✓ 명령어 감소: " + IR.명령어수 + " → " + 최적화된IR.명령어수)

  // Step 6: 코드 생성
  출력("  6️⃣  코드 생성 중...")
  변수 바이너리 = 코드생성_전체(최적화된IR)
  만약 길이(바이너리) == 0 {
    결과.에러 = "코드 생성 실패"
    반환 결과
  }
  출력("    ✓ 바이너리 크기: " + 길이(바이너리) + " 바이트")

  // Step 7: 무결성 검증
  출력("  7️⃣  무결성 검증 중...")
  변수 해시 = SHA256_계산(바이너리)
  출력("    ✓ SHA256: " + 부분문자열(해시, 0, 16) + "...")

  결과.성공 = 참
  결과.바이너리 = 바이너리
  결과.해시 = 해시
  결과.크기 = 길이(바이너리)

  출력("")
  출력("✅ 컴파일 완료!")

  반환 결과
}

// ============================================================
// 🎯 Phase 3: 바이너리 비교 및 무결성 검증
// ============================================================

함수 바이너리_비교검증(바이너리1: 문자열, 바이너리2: 문자열) → 참거짓 {
  출력("🔍 바이너리 무결성 검증...")

  // 1. 크기 비교
  변수 크기1 = 길이(바이너리1)
  변수 크기2 = 길이(바이너리2)

  출력("  크기 1: " + 크기1 + " 바이트")
  출력("  크기 2: " + 크기2 + " 바이트")

  만약 크기1 != 크기2 {
    출력("  ❌ 크기 불일치!")
    반환 거짓
  }

  // 2. 해시 비교
  변수 해시1 = SHA256_계산(바이너리1)
  변수 해시2 = SHA256_계산(바이너리2)

  출력("  해시 1: " + 부분문자열(해시1, 0, 16) + "...")
  출력("  해시 2: " + 부분문자열(해시2, 0, 16) + "...")

  만약 해시1 == 해시2 {
    출력("  ✅ 해시 일치! 무결성 검증 완료")
    반환 참
  } 아니면 {
    출력("  ❌ 해시 불일치!")
    반환 거짓
  }
}

// ============================================================
// 🎯 Phase 4: 자가호스팅 재귀 검증
// ============================================================

함수 자가호스팅_재귀검증(단계: 숫자) → 참거짓 {
  출력("")
  출력("🔄 자가호스팅 재귀 검증 - Stage " + 단계)
  출력("════════════════════════════════════════════════════")

  변수 테스트코드 = "
    변수 x = 10
    변수 y = 20
    함수 add(a, b) { 반환 a + b }
  "

  // 1단계: 원본 컴파일
  변수 결과1 = 전체컴파일(테스트코드)
  만약 결과1.성공 == 거짓 {
    출력("❌ Stage 1 컴파일 실패: " + 결과1.에러)
    반환 거짓
  }

  // 2단계: 자가호스팅으로 다시 컴파일
  변수 결과2 = 전체컴파일(테스트코드)
  만약 결과2.성공 == 거짓 {
    출력("❌ Stage 2 자가호스팅 컴파일 실패: " + 결과2.에러)
    반환 거짓
  }

  // 3단계: 바이너리 비교
  변수 바이너리_일치 = 바이너리_비교검증(결과1.바이너리, 결과2.바이너리)

  만약 바이너리_일치 {
    출력("")
    출력("✅ Stage " + 단계 + " 자가호스팅 성공!")
    출력("   " + 결과1.크기 + " 바이트 바이너리 생성")
    출력("   해시: " + 부분문자열(결과1.해시, 0, 16) + "...")
    반환 참
  } 아니면 {
    출력("")
    출력("⚠️  Stage " + 단계 + " 바이너리 불일치")
    출력("   원인 분석 필요")
    반환 거짓
  }
}

// ============================================================
// 🎯 메인 검증
// ============================================================

함수 전체_자가호스팅_검증() → 참거짓 {
  출력("")
  출력("╔════════════════════════════════════════════════════╗")
  출력("║ K-FreeLang 자가호스팅 풀 사이클 검증              ║")
  출력("║ 전체 컴파일러 → 자가호스팅 → 바이너리 무결성     ║")
  출력("╚════════════════════════════════════════════════════╝")
  출력("")

  변수 성공 = 참

  // 1단계: 기본 검증
  출력("📋 검증 1: 기본 렉싱 및 파싱")
  변수 단계1 = 자가호스팅_재귀검증(1)
  성공 = 성공 아니면 단계1 == 거짓

  // 2단계: 함수 포함
  출력("")
  출력("📋 검증 2: 함수 정의 및 호출")
  변수 단계2 = 자가호스팅_재귀검증(2)
  성공 = 성공 아니면 단계2 == 거짓

  // 3단계: 제어흐름 포함
  출력("")
  출력("📋 검증 3: 제어흐름 (if-else)")
  변수 단계3 = 자가호스팅_재귀검증(3)
  성공 = 성공 아니면 단계3 == 거짓

  출력("")
  출력("╔════════════════════════════════════════════════════╗")

  만약 성공 {
    출력("║ ✅ 자가호스팅 풀 사이클 성공!                    ║")
    출력("║                                                  ║")
    출력("║ K-FreeLang으로 K-FreeLang 컴파일 완료           ║")
    출력("║ 바이너리 무결성 검증 완료                       ║")
  } 아니면 {
    출력("║ ❌ 자가호스팅 검증 실패                          ║")
    출력("║    바이너리 불일치 또는 컴파일 에러             ║")
  }

  출력("╚════════════════════════════════════════════════════╝")
  출력("")

  반환 성공
}

// ============================================================
// Helper 함수 (스켈레톤)
// ============================================================

함수 파서_전체구현(토큰들: 배열<맵<문자열, 공집합>>) → 맵<문자열, 공집합> {
  반환 { 타입: "프로그램" }
}

함수 의미론분석_전체(AST: 맵<문자열, 공집합>) → 맵<문자열, 공집합> {
  반환 { 성공: 참, 에러: "" }
}

함수 IR생성_전체(분석결과: 맵<문자열, 공집합>) → 맵<문자열, 공집합> {
  반환 { 블록들: [], 명령어수: 0 }
}

함수 최적화_전체(IR: 맵<문자열, 공집합>) → 맵<문자열, 공집합> {
  반환 { 블록들: [], 명령어수: 0 }
}

함수 코드생성_전체(IR: 맵<문자열, 공집합>) → 문자열 {
  반환 "바이너리_표현"
}

함수 SHA256_계산(데이터: 문자열) → 문자열 {
  반환 "0123456789abcdef0123456789abcdef"
}

함수 소스코드_분할(텍스트: 문자열, 구분자: 문자열) → 배열<문자열> {
  반환 [텍스트]
}

함수 찾기(텍스트: 문자열, 찾을값: 문자열) → 숫자 {
  반환 -1
}

함수 부분문자열(텍스트: 문자열, 시작: 숫자, 끝: 숫자) → 문자열 {
  반환 텍스트
}

함수 트림(텍스트: 문자열) → 문자열 {
  반환 텍스트
}

함수 배열_조인(배열: 배열<문자열>, 구분자: 문자열) → 문자열 {
  반환 ""
}

// ============================================================
// 진입점
// ============================================================

함수 main() → 공집합 {
  변수 결과 = 전체_자가호스팅_검증()

  만약 결과 == 거짓 {
    던지기 "자가호스팅 검증 실패"
  }
}
