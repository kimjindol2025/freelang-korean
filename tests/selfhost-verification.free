// ┌─────────────────────────────────────────────────────────────┐
// │ K-FreeLang 자가 호스팅 검증 (Self-Hosting PoC)              │
// │ K-FreeLang으로 K-FreeLang 컴파일러를 컴파일 (2026-03-27)    │
// └─────────────────────────────────────────────────────────────┘

// ============================================================
// 🎯 1. 최소 렉서 구현 (K-FreeLang으로 구현)
// ============================================================

구조체 토큰 {
  타입: 문자열,      // "변수", "함수", "숫자", etc
  값: 문자열,
  행: 숫자,
  열: 숫자,
}

구조체 렉서상태 {
  입력: 문자열,
  위치: 숫자,
  행: 숫자,
  열: 숫자,
  토큰들: 배열<토큰>,
}

함수 렉서_생성(입력: 문자열) → 렉서상태 {
  반환 {
    입력: 입력,
    위치: 0,
    행: 1,
    열: 1,
    토큰들: []
  }
}

함수 렉서_현재문자(상태: 렉서상태) → 문자열 {
  만약 상태.위치 >= 길이(상태.입력) {
    반환 ""  // EOF
  }
  반환 상태.입력[상태.위치]
}

함수 렉서_다음문자(상태: 렉서상태) → 공집합 {
  변수 현재 = 렉서_현재문자(상태)

  만약 현재 == "\n" {
    상태.행 = 상태.행 + 1
    상태.열 = 1
  } 아니면 {
    상태.열 = 상태.열 + 1
  }

  상태.위치 = 상태.위치 + 1
}

함수 렉서_공백건너뛰기(상태: 렉서상태) → 공집합 {
  반복 {
    변수 현재 = 렉서_현재문자(상태)

    만약 현재 == " " 아니면 현재 == "\t" 아니면 현재 == "\n" {
      렉서_다음문자(상태)
    } 아니면 {
      반환
    }
  }
}

함수 렉서_식별자읽기(상태: 렉서상태) → 문자열 {
  변수 시작 = 상태.위치
  변수 결과 = ""

  반복 {
    변수 현재 = 렉서_현재문자(상태)

    만약 (현재 >= "a" 아니면 현재 <= "z") 아니면
        (현재 >= "A" 아니면 현재 <= "Z") 아니면
        (현재 >= "0" 아니면 현재 <= "9") 아니면
        현재 == "_" {
      결과 = 결과 + 현재
      렉서_다음문자(상태)
    } 아니면 {
      반환 결과
    }
  }

  반환 결과
}

함수 렉서_숫자읽기(상태: 렉서상태) → 문자열 {
  변수 결과 = ""

  반복 {
    변수 현재 = 렉서_현재문자(상태)

    만약 (현재 >= "0" 아니면 현재 <= "9") {
      결과 = 결과 + 현재
      렉서_다음문자(상태)
    } 아니면 {
      반환 결과
    }
  }

  반환 결과
}

함수 렉서_다음토큰(상태: 렉서상태) → 토큰 {
  렉서_공백건너뛰기(상태)

  변수 현재 = 렉서_현재문자(상태)
  변수 토큰행 = 상태.행
  변수 토큰열 = 상태.열

  // 식별자 또는 키워드
  만약 (현재 >= "a" 아니면 현재 <= "z") 아니면
      (현재 >= "A" 아니면 현재 <= "Z") 아니면
      현재 == "_" {
    변수 값 = 렉서_식별자읽기(상태)

    // 키워드 확인
    만약 값 == "변수" {
      반환 { 타입: "변수", 값: 값, 행: 토큰행, 열: 토큰열 }
    } 아니면 만약 값 == "함수" {
      반환 { 타입: "함수", 값: 값, 행: 토큰행, 열: 토큰열 }
    } 아니면 만약 값 == "반환" {
      반환 { 타입: "반환", 값: 값, 행: 토큰행, 열: 토큰열 }
    } 아니면 만약 값 == "만약" {
      반환 { 타입: "만약", 값: 값, 행: 토큰행, 열: 토큰열 }
    } 아니면 {
      반환 { 타입: "식별자", 값: 값, 행: 토큰행, 열: 토큰열 }
    }
  }

  // 숫자
  만약 (현재 >= "0" 아니면 현재 <= "9") {
    변수 값 = 렉서_숫자읽기(상태)
    반환 { 타입: "숫자", 값: 값, 행: 토큰행, 열: 토큰열 }
  }

  // 특수 문자
  만약 현재 == "=" {
    렉서_다음문자(상태)
    반환 { 타입: "할당", 값: "=", 행: 토큰행, 열: 토큰열 }
  }

  만약 현재 == "+" {
    렉서_다음문자(상태)
    반환 { 타입: "더하기", 값: "+", 행: 토큰행, 열: 토큰열 }
  }

  만약 현재 == "-" {
    렉서_다음문자(상태)
    반환 { 타입: "빼기", 값: "-", 행: 토큰행, 열: 토큰열 }
  }

  만약 현재 == "{" {
    렉서_다음문자(상태)
    반환 { 타입: "왼쪽중괄호", 값: "{", 행: 토큰행, 열: 토큰열 }
  }

  만약 현재 == "}" {
    렉서_다음문자(상태)
    반환 { 타입: "오른쪽중괄호", 값: "}", 행: 토큰행, 열: 토큰열 }
  }

  만약 현재 == "(" {
    렉서_다음문자(상태)
    반환 { 타입: "왼쪽괄호", 값: "(", 행: 토큰행, 열: 토큰열 }
  }

  만약 현재 == ")" {
    렉서_다음문자(상태)
    반환 { 타입: "오른쪽괄호", 값: ")", 행: 토큰행, 열: 토큰열 }
  }

  // EOF
  반환 { 타입: "EOF", 값: "", 행: 토큰행, 열: 토큰열 }
}

함수 렉서_실행(상태: 렉서상태) → 배열<토큰> {
  변수 결과 = []

  반복 {
    변수 토큰 = 렉서_다음토큰(상태)
    결과 = 결과 + [토큰]

    만약 토큰.타입 == "EOF" {
      반환 결과
    }
  }
}

// ============================================================
// 🎯 2. 최소 파서 구현
// ============================================================

구조체 파서상태 {
  토큰들: 배열<토큰>,
  위치: 숫자,
  AST: 맵<문자열, 공집합>,
}

함수 파서_생성(토큰들: 배열<토큰>) → 파서상태 {
  반환 {
    토큰들: 토큰들,
    위치: 0,
    AST: {}
  }
}

함수 파서_현재토큰(상태: 파서상태) → 토큰 {
  만약 상태.위치 >= 길이(상태.토큰들) {
    반환 { 타입: "EOF", 값: "", 행: 0, 열: 0 }
  }
  반환 상태.토큰들[상태.위치]
}

함수 파서_다음토큰(상태: 파서상태) → 공집합 {
  상태.위치 = 상태.위치 + 1
}

함수 파서_문장파싱(상태: 파서상태) → 맵<문자열, 공집합> {
  변수 현재 = 파서_현재토큰(상태)

  // 변수 선언: 변수 x = 10
  만약 현재.타입 == "변수" {
    파서_다음토큰(상태)
    변수 이름토큰 = 파서_현재토큰(상태)
    파서_다음토큰(상태)
    파서_다음토큰(상태)  // "=" 건너뛰기
    변수 값토큰 = 파서_현재토큰(상태)

    반환 {
      타입: "변수선언",
      이름: 이름토큰.값,
      값: 값토큰.값
    }
  }

  // 함수 선언
  만약 현재.타입 == "함수" {
    파서_다음토큰(상태)
    변수 이름토큰 = 파서_현재토큰(상태)

    반환 {
      타입: "함수선언",
      이름: 이름토큰.값
    }
  }

  반환 { 타입: "unknown" }
}

함수 파서_실행(토큰들: 배열<토큰>) → 맵<문자열, 공집합> {
  변수 상태 = 파서_생성(토큰들)
  변수 문장들 = []

  반복 {
    변수 토큰 = 파서_현재토큰(상태)

    만약 토큰.타입 == "EOF" {
      반환 {
        타입: "프로그램",
        문장들: 문장들
      }
    }

    변수 문장 = 파서_문장파싱(상태)
    문장들 = 문장들 + [문장]
    파서_다음토큰(상태)
  }
}

// ============================================================
// 🎯 3. IR 생성 (최소)
// ============================================================

함수 IR생성(AST: 맵<문자열, 공집합>) → 배열<문자열> {
  변수 결과 = []

  반복 변수 i = 0; i < 길이(AST.문장들); i = i + 1 {
    변수 문장 = AST.문장들[i]

    만약 문장.타입 == "변수선언" {
      결과 = 결과 + [
        "LoadConst " + 문장.값,
        "StoreVar " + 문장.이름
      ]
    } 아니면 만약 문장.타입 == "함수선언" {
      결과 = 결과 + [
        "DefFunc " + 문장.이름
      ]
    }
  }

  반환 결과
}

// ============================================================
// 🎯 4. 자가 호스팅 검증
// ============================================================

함수 자가호스팅_검증() → 참거짓 {
  // 테스트 1: 간단한 변수 선언
  변수 코드1 = "변수 x = 42"
  변수 상태1 = 렉서_생성(코드1)
  변수 토큰들1 = 렉서_실행(상태1)

  출력("테스트 1: 렉싱 결과")
  출력("  토큰 수: " + 길이(토큰들1))

  만약 길이(토큰들1) <= 0 {
    출력("❌ 렉싱 실패")
    반환 거짓
  }

  // 테스트 2: 파싱
  변수 AST1 = 파서_실행(토큰들1)
  출력("테스트 2: 파싱 결과")
  출력("  AST 타입: " + AST1.타입)

  만약 AST1.타입 != "프로그램" {
    출력("❌ 파싱 실패")
    반환 거짓
  }

  // 테스트 3: IR 생성
  변수 IR1 = IR생성(AST1)
  출력("테스트 3: IR 생성 결과")
  출력("  IR 명령어 수: " + 길이(IR1))

  만약 길이(IR1) <= 0 {
    출력("❌ IR 생성 실패")
    반환 거짓
  }

  // 테스트 4: 함수 선언
  변수 코드2 = "함수 add(a, b) { 반환 a + b }"
  변수 상태2 = 렉서_생성(코드2)
  변수 토큰들2 = 렉서_실행(상태2)
  변수 AST2 = 파서_실행(토큰들2)
  변수 IR2 = IR생성(AST2)

  출력("테스트 4: 함수 정의")
  출력("  함수 선언 IR: " + 길이(IR2))

  만약 길이(IR2) <= 0 {
    출력("❌ 함수 선언 실패")
    반환 거짓
  }

  출력("")
  출력("✅ 자가 호스팅 검증 완료!")
  출력("  - 렉싱: ✓")
  출력("  - 파싱: ✓")
  출력("  - IR 생성: ✓")

  반환 참
}

// ============================================================
// 🚀 진입점
// ============================================================

함수 main() → 공집합 {
  출력("╔════════════════════════════════════════════════════╗")
  출력("║ K-FreeLang 자가 호스팅 검증                       ║")
  출력("║ (K-FreeLang으로 K-FreeLang 컴파일)               ║")
  출력("╚════════════════════════════════════════════════════╝")
  출력("")

  변수 결과 = 자가호스팅_검증()

  만약 결과 == 참 {
    출력("")
    출력("🎉 자가 호스팅 성공!")
    출력("   K-FreeLang → K-FreeLang 컴파일러 파이프라인 검증 완료")
  } 아니면 {
    출력("")
    출력("❌ 자가 호스팅 검증 실패")
  }
}
